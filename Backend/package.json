{
  "name": "@verve/backend",
  "version": "0.1.0",
  "description": "Verve Dental Operational Suite — Node.js/TypeScript API server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "node ../node_modules/typescript/lib/tsc.js -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "node ../node_modules/typescript/lib/tsc.js --noEmit",
    "lint": "node ../node_modules/eslint/bin/eslint.js src tests",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js",
    "migrate": "node ./node_modules/tsx/dist/cli.mjs src/db/runMigrate.ts",
    "test:coverage": "npm run test -- --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.1",
    "pg": "^8.21.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.28.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
