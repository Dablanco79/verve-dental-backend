NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins, or * for any origin.
# Production: set to your deployed frontend URL(s), e.g. https://app.vervedental.com.au
# Multiple origins: https://app.example.com,https://staging.example.com
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL) — use AWS Secrets Manager in deployed environments
# Required once Module 02 (Auth) or Module 13 (DB) is wired in.
DATABASE_URL=postgresql://user:password@localhost:5432/verve_dev
# SSL: auto (default) | true | false — auto enables SSL for remote hosts and sslmode=require URLs
DATABASE_SSL=auto

# Redis — caching layer (required from Module 05 onwards)
REDIS_URL=redis://localhost:6379
# TLS: auto (default) | true | false — auto enables TLS for rediss:// URLs
REDIS_TLS=auto

# JWT — use AWS Secrets Manager in deployed environments (min 32 chars each)
JWT_ACCESS_SECRET=dev-access-secret-change-me-before-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-before-production-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MFA — AES-256-GCM encryption of totp_secret at rest (Sprint 2D).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required: server will not start without a valid 64-character hex key.
MFA_ENCRYPTION_KEY=replace-me-with-64-char-hex-from-the-command-above-0000000000000

# ── Supplier Invoice OCR (Sprint OCR-1) ─────────────────────────────────────
# Primary OCR provider. Supported values: anthropic (default)
OCR_PROVIDER=anthropic

# Anthropic Claude API key — required when OCR_PROVIDER=anthropic in staging/production.
# Obtain from https://console.anthropic.com/
# In development/test: omit or leave blank to use the built-in stub provider.
ANTHROPIC_API_KEY=

# Claude model used for invoice extraction. Override to pin a specific version.
OCR_CLAUDE_MODEL=claude-opus-4-5

# Maximum uploaded file size in bytes (default: 20 MB).
OCR_MAX_FILE_SIZE_BYTES=20971520
